# BlawbyAgent (macOS) environment example
# Copy to agent-mac/.env for local development.

# WebSocket/worker auth (can come from agent/.env)
WORKER_WS_URL=wss://sky-ai.paulchrisluke.workers.dev
WORKER_API_KEY=replace_me
WORKSPACE_ID=default
ACCOUNT_ID=replace_me_account

# OpenAI extraction (can come from .dev.vars)
OPENAI_API_KEY=replace_me_openai_key
OPENAI_MODEL=gpt-4o-mini

# Sparkle updater (required for release update checks)
SPARKLE_FEED_URL=https://downloads.blawby.com/appcast.xml
SPARKLE_PUBLIC_ED_KEY=replace_me_sparkle_public_ed25519_key
