# Copy to .dev.vars for local development.
# Do not commit .dev.vars.

AIG_ACCOUNT_ID="replace-me"
AIG_GATEWAY_ID="sky-ai"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_API_KEY="replace-me"
WORKER_API_KEY="replace-me"
MAILBOX_SKYLERBAIRD_ME_COM="SkylerBaird@me.com"
CF_AIG_AUTH_TOKEN="replace-me"
ACCESS_ISSUER="https://<team>.cloudflareaccess.com"
ACCESS_JWKS_URL="https://<team>.cloudflareaccess.com/cdn-cgi/access/certs"
ACCESS_AUD="replace-me"

# Optional per-1M unit pricing for Workers AI cost estimation.
# Leave unset to report usage units with unknown (null) estimated cost for Workers AI rows.
WORKERS_AI_INPUT_COST_PER_1M=""
WORKERS_AI_OUTPUT_COST_PER_1M=""
OPENAI_QUOTA_COOLDOWN_MINUTES="1440"
OPENAI_RATE_LIMIT_COOLDOWN_MINUTES="5"

# Optional for scripts/validate-api-e2e.sh (Access service-token E2E checks):
CF_ACCESS_CLIENT_ID="replace-me"
CF_ACCESS_CLIENT_SECRET="replace-me"
