GOOGLE_CLIENT_SECRET="replace-me"
GOOGLE_REDIRECT_URI="http://localhost:8787/oauth/callback"
TOKEN_ENCRYPTION_KEY="replace-me"
AIG_ACCOUNT_ID="replace-me"
AIG_GATEWAY_ID="replace-me"
